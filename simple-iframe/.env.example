# Ear3 publishable key — safe to expose in the browser bundle.
# Grab yours from: https://app.ear3.ai/settings/api-keys
NEXT_PUBLIC_EAR3_PUBLISHABLE_KEY=pk_test_...

# The interview to run. This is a "deployment id" from the Ear3 dashboard.
# Grab yours from: https://app.ear3.ai/interviews (open a deployment → copy id)
NEXT_PUBLIC_EAR3_INTERVIEW_ID=cm_...

# Optional — override Ear3 host. Defaults to https://app.ear3.ai (prod).
# Use https://dev.ear3.ai when testing against staging.
# NEXT_PUBLIC_EAR3_API_BASE=https://dev.ear3.ai
