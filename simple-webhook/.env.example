# Browser-safe key — exposed in the client bundle.
NEXT_PUBLIC_EAR3_PUBLISHABLE_KEY=pk_test_...

# Interview (deployment id) — see https://app.ear3.ai/interviews
NEXT_PUBLIC_EAR3_INTERVIEW_ID=cm_...

# Server-only — do NOT prefix with NEXT_PUBLIC_.
# Grab both from https://app.ear3.ai/settings/api-keys
EAR3_SECRET_KEY=sk_test_...

# HMAC-SHA256 shared secret for verifying incoming webhook signatures.
# Set the same value in the Ear3 dashboard when you register your endpoint.
EAR3_WEBHOOK_SECRET=whsec_...
